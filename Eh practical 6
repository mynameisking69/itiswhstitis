P6 LOGISTIC REGRESSION
library(MASS)
data(biopsy)
head(biopsy)
str(biopsy)
biopsy$ID = NULL
names(biopsy) =c("thick","usize","ushape","adhsn",
"celsiz","nucl","chrom",
"nuclus","mit","class")
colSums(is.na(biopsy))
biopsy1 = na.omit(biopsy)
set.seed(123)
ind = sample(2, nrow(biopsy1), replace = TRUE, prob = c(0.7, 0.3))
train = biopsy1[ind == 1, ]
test = biopsy1[ind == 2, ]
fullfit = glm(class ~ ., family = binomial, data = train)
summary(fullfit)
test$prob = predict(fullfit, newdata = test, type = "response")
test$predict = rep("benign", nrow(test))
test$predict[test$prob < 0.5] = "malignant"
table(test$predict, test$class)
mean(test$predict == test$class)
library(ROCR)
ROCRpred = predicƟon(test$prob, test$class)
ROCRperf = performance(ROCRpred, "tpr", "fpr")
plot(ROCRperf, colorize = TRUE)
